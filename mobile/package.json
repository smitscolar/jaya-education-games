    "react-native-screens": "^3.27.0",
    "react-navigation": "^6.1.9",
    "react-navigation-bottom-tabs": "^6.5.20",
    "react-navigation-native": "^6.1.9",
    "redux": "^4.2.1",
    "react-redux": "^8.1.3",
    "redux-thunk": "^2.4.2",
    "firebase": "^10.7.0",
    "@react-native-firebase/app": "^18.7.0",
